companies/concise/books-source/
# Playwright MCP session artifacts (debug logs + page snapshots from agent browser sessions)
**/.playwright-mcp/
# Runtime logs from infrastructure/scripts/ (cost tracking, idempotency markers, purchase history)
infrastructure/scripts/.image-gen-costs.jsonl
infrastructure/scripts/.domain-purchases.jsonl
infrastructure/scripts/.watchdog-log.jsonl
infrastructure/scripts/.token-log.jsonl
infrastructure/scripts/.*-log.jsonl
# Next.js build output (should never be committed)
companies/*/.next/
companies/*/node_modules/
**/.next/
**/node_modules/
