# Concise Environment Variables (Local Development)
# Copy this file to .env.local and fill in actual values

# Supabase (shared across AgentCompanies, provided in parent .env)
SUPABASE_URL=https://jivahkfdkduxasnzpzgx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-from-root-env-or-supabase-dashboard

# Lemon Squeezy (SEALED product payment + digital PDF delivery)
# Store: Demiurgic Labs (ID: 363520)
# Get API key from: https://app.lemonsqueezy.com/settings/api
# CON-25 acceptance: sandbox test first, then live flip after CEO + CFO approval
LEMONSQUEEZY_API_KEY=your-api-key-here
LEMONSQUEEZY_STORE_ID=363520

# Mailchimp (SEALED audience - for email capture automation)
# Get these from https://mailchimp.com/account/api
# API Key format: abc123def456ghi789jkl012mno345pq-us1
# Extract API key and DC region separately
MAILCHIMP_API_KEY=your-api-key-here
MAILCHIMP_AUDIENCE_ID=your-audience-id-here
MAILCHIMP_DC_REGION=us1

# Stripe (when adding payment processing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (alternative email provider - currently not used, kept for reference)
# RESEND_API_KEY=re_...
