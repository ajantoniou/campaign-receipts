{
  "manifest_version": 3,
  "name": "Campaign Receipts Edge",
  "version": "1.0",
  "description": "Live donor influence data overlay for prediction markets.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.polymarket.com/*",
    "https://*.campaignreceipts.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Campaign Receipts Edge"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/event/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
